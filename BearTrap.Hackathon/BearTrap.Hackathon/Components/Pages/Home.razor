@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable

@using BearTrap.Hackathon.Domain
@using BearTrap.Hackathon.Application.Services
@using BearTrap.Hackathon.Services.DataSources
@using System.Globalization

@inject IFourMemeSource FourMemeSource
@inject IFourMemeMainListSource FourMemeMainListSource
@inject RiskAnalyzer RiskAnalyzer
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<PageTitle>BearTrap Hackathon</PageTitle>

<div class="page-wrapper">
    <!-- Centered Panel Container -->
    <div class="main-panel">
        <!-- Header Area -->
        <div class="header-area">
            <h1 class="dash-title">BearTrap Token Risk Analysis</h1>
            <div class="dash-subtitle">
                <span class="subtitle-inline">
                    <span>Hackathon Edition</span>
                    <span class="edition-badge">Four.Meme-listed Tokens</span>
                </span>
            </div>
            
            <div class="controls-grid">
                <div class="order-wrapper">
                    <label class="order-label" for="orderBySelect">Order by</label>
                    <select id="orderBySelect"
                            class="order-select"
                            value="@_selectedOrderBy"
                            @onchange="OnOrderByChangedAsync">
                        <option value="@FourMemeOrderBy.Hot">Featured</option>
                        <option value="@FourMemeOrderBy.TimeDesc">Creation Time</option>
                        <option value="@FourMemeOrderBy.TradingVolume">Trading Volume</option>
                        <option value="@FourMemeOrderBy.Progress">Progress</option>
                        <option value="@FourMemeOrderBy.LastTrade">Last Trade</option>
                    </select>
                </div>

                <!-- Search Bar (Pill Style) -->
                <div class="search-wrapper">
                    <input type="text" 
                           class="search-pill" 
                           placeholder="Search by name, symbol, token or creator..."
                           @bind="_searchQuery"
                           @bind:event="oninput"
                           @onkeydown="OnSearchInputKeyDown" />
                    <button type="button"
                            class="search-trigger"
                            title="Search"
                            aria-label="Search"
                            @onclick="SearchAsync">
                        <span class="search-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                <line x1="16.65" y1="16.65" x2="21" y2="21" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    </button>
                </div>
            </div>
           
        </div>
        
        <!-- Token List Content -->
        <div class="tokens-content">
            @if (_loading)
            {
                <div class="loading-state">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3">Loading tokens...</p>
                </div>
            }
            else if (FilteredResults.Count == 0)
            {
                <div class="empty-state">
                    @if (IsSearchMode)
                    {
                        <p>
                            No results.
                            <button type="button" class="empty-link" @onclick="ShowFeaturedAsync">Show Featured</button>
                        </p>
                    }
                    else
                    {
                        <p>No tokens found.</p>
                    }
                </div>
            }
            else
            {
                <div class="token-grid">
                    @foreach (var row in FilteredResults)
                    {
                        <div class="tcard">
                            <!-- Top Section: Avatar + Metadata | Gauge + Risk Pill -->
                            <div class="tcard-top token-header">
                                <div class="tleft">
                                    <img class="timg token-avatar"
                                         src="@(string.IsNullOrWhiteSpace(row.Token.ImageUrl) ? "/mock-images/token-placeholder.svg" : row.Token.ImageUrl)"
                                         alt="@row.Token.Name"
                                         loading="lazy"
                                         onerror="this.src='/mock-images/token-placeholder.svg';" />
                                    
                                    <div class="tmeta token-addresses">
                                        <div class="tname-row">
                                            <div class="tname">@row.Token.Name</div>
                                            <span class="tchain-pill">@(!string.IsNullOrWhiteSpace(row.Token.Symbol) ? row.Token.Symbol : "-")</span>
                                        </div>
                                        <div class="addr-stack">
                                            <div class="addr-row">
                                                <span class="addr-label">Token</span>
                                                <a href="#"
                                                   class="addr-value"
                                                   @onclick:preventDefault="true"
                                                   @onclick="() => CopyToClipboard(row.Token.Address)"
                                                                    title="Copy token address">@row.Token.Address</a>
                                                <span class="addr-actions">
                                                    <button type="button"
                                                            class="addr-copy"
                                                            @onclick="() => CopyToClipboard(row.Token.Address)"
                                                            title="Copy token address">⧉</button>
                                                    <a href="@GetFourMemeTokenUrl(row.Token.Address)"
                                                       class="addr-open"
                                                       title="Open on Four.meme"
                                                       target="_blank"
                                                       rel="noopener noreferrer"
                                                       @onclick:stopPropagation="true"
                                                       aria-label="Open token on Four.meme">
                                                        <svg viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                                                            <path d="M14 5h5v5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                                            <path d="M10 14L19 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                                            <path d="M19 14v5h-14v-14h5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                                        </svg>
                                                    </a>
                                                </span>
                                            </div>
                                            <div class="addr-row">
                                                <span class="addr-label">Creator</span>
                                                <a href="#"
                                                   class="addr-value"
                                                   @onclick:preventDefault="true"
                                                   @onclick="() => CopyToClipboard(row.Token.Creator)"
                                                                    title="Copy creator address">@row.Token.Creator</a>
                                                <span class="addr-actions">
                                                    <button type="button"
                                                            class="addr-copy"
                                                            @onclick="() => CopyToClipboard(row.Token.Creator)"
                                                            title="Copy creator address">⧉</button>
                                                    @if (!string.IsNullOrWhiteSpace(row.Token.CreatorUserId))
                                                    {
                                                        <a href="@GetFourMemeUserUrl(row.Token.CreatorUserId)"
                                                           class="addr-open"
                                                           title="Open on Four.meme"
                                                           target="_blank"
                                                           rel="noopener noreferrer"
                                                           @onclick:stopPropagation="true"
                                                           aria-label="Open creator on Four.meme">
                                                            <svg viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                                                                <path d="M14 5h5v5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                                                <path d="M10 14L19 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                                                <path d="M19 14v5h-14v-14h5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                                            </svg>
                                                        </a>
                                                    }
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="tright token-gauge">
                                    @{
                                        var scorePercent = row.Report.Score;
                                    }
                                    <div class="risk-gauge">
                                        <svg class="gauge-svg" viewBox="0 0 120 70" xmlns="http://www.w3.org/2000/svg">
                                            <defs>
                                                <!-- Gradient for low risk -->
                                                <linearGradient id="gradient-low" x1="0%" y1="0%" x2="100%" y2="0%">
                                                    <stop offset="0%" style="stop-color:#2fb67c;stop-opacity:1" />
                                                    <stop offset="100%" style="stop-color:#22c55e;stop-opacity:1" />
                                                </linearGradient>
                                                <!-- Gradient for medium risk -->
                                                <linearGradient id="gradient-med" x1="0%" y1="0%" x2="100%" y2="0%">
                                                    <stop offset="0%" style="stop-color:#f59e0b;stop-opacity:1" />
                                                    <stop offset="100%" style="stop-color:#e89b2f;stop-opacity:1" />
                                                </linearGradient>
                                                <!-- Gradient for high risk -->
                                                <linearGradient id="gradient-high" x1="0%" y1="0%" x2="100%" y2="0%">
                                                    <stop offset="0%" style="stop-color:#dc5a55;stop-opacity:1" />
                                                    <stop offset="100%" style="stop-color:#e06b67;stop-opacity:1" />
                                                </linearGradient>
                                                <filter id="gauge-shadow" x="-20%" y="-20%" width="140%" height="140%">
                                                    <feGaussianBlur in="SourceAlpha" stdDeviation="1.5"/>
                                                    <feOffset dx="0" dy="1" result="offsetblur"/>
                                                    <feComponentTransfer>
                                                        <feFuncA type="linear" slope="0.12"/>
                                                    </feComponentTransfer>
                                                    <feMerge>
                                                        <feMergeNode/>
                                                        <feMergeNode in="SourceGraphic"/>
                                                    </feMerge>
                                                </filter>
                                            </defs>
                                            <!-- Background arc -->
                                            <path class="gauge-bg"
                                                  d="M10,60 A50,50 0 0 1 110,60"
                                                  pathLength="100"
                                                  fill="none"
                                                  stroke="rgba(15, 23, 42, 0.10)"
                                                  stroke-width="15"
                                                  stroke-linecap="round"/>
                                            <!-- Foreground arc (progress) - single continuous segment -->
                                            <path class="gauge-fg"
                                                  d="M10,60 A50,50 0 0 1 110,60"
                                                  pathLength="100"
                                                  fill="none"
                                                  stroke="url(#gradient-@(scorePercent <= 30 ? "low" : scorePercent <= 60 ? "med" : "high"))"
                                                  stroke-width="15"
                                                  stroke-linecap="round"
                                                  style="--p:@scorePercent"
                                                  filter="url(#gauge-shadow)"/>
                                        </svg>
                                        <div class="gauge-content">
                                            <div class="gauge-num">@row.Report.Score</div>
                                            <div class="gauge-label gauge-label-@GetScoreSeverity(row.Report.Score)">@GetRiskLabel(row.Report.Score)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @{
                                var tokenLinks = BuildTokenLinks(row.Token, row.Report);
                            }

                            @if (tokenLinks.Any())
                            {
                                <div class="token-links" aria-label="Token links">
                                    @foreach (var link in tokenLinks)
                                    {
                                        <a class="btn btn-sm btn-outline-secondary token-link-btn"
                                           href="@link.Url"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           title="@link.Url">
                                            @link.Label
                                        </a>
                                    }
                                </div>
                            }
                            
                            <!-- Bottom Strip: Flags -->
                            <div class="tcard-bottom" id="@GetFlagsContainerId(row.Token.Address)" data-flags-token-key="@NormalizeTokenKey(row.Token.Address)">
                                @{
                                    var displayFlags = row.Report.DisplayFlags.ToList();
                                    var riskReasonByCode = row.Report.Flags
                                        .GroupBy(f => f.Code, StringComparer.OrdinalIgnoreCase)
                                        .ToDictionary(g => g.Key, g => g.First().Detail, StringComparer.OrdinalIgnoreCase);
                                }

                                <div class="risk-row">
                                    <div class="risk-pills" data-risk-container="true">
                                        @foreach (var flag in displayFlags)
                                        {
                                            var reason = riskReasonByCode.TryGetValue(flag.Code, out var detail) ? detail : string.Empty;

                                            <span class="tchip tchip-flag flag-chip"
                                                  data-risk-pill="true"
                                                  data-risk-code="@flag.Code"
                                                  data-risk-title="@flag.Label"
                                                  data-risk-points="@flag.Points"
                                                  data-total-score="@row.Report.Score"
                                                  data-risk-severity="@flag.Severity"
                                                  data-risk-reason="@reason"
                                                  data-flag-label="@flag.Label"
                                                  title="@flag.Code: @flag.Label (+@flag.Points pts)">
                                                @flag.Label
                                            </span>
                                        }

                                        @if (!displayFlags.Any())
                                        {
                                            <span class="tchip tchip-clean">✓ Clean</span>
                                        }
                                    </div>

                                    <span class="tchip tchip-more more-chip risk-more is-hidden"
                                          data-risk-more="true"
                                          title=""
                                          aria-hidden="true"
                                          tabindex="-1"></span>
                                </div>
                            </div>

                            <div class="tcard-progress-section">
                                @if (row.Token.ProgressPercent.HasValue)
                                {
                                    var progressPercent = row.Token.ProgressPercent.Value;

                                    <div class="tcard-progress-header">
                                        <span class="tcard-progress-label">Bonding Curve</span>
                                        <span class="tcard-progress-value">@progressPercent.ToString("0")%</span>
                                    </div>
                                    <div class="bt-progress" role="progressbar" aria-label="Bonding Curve" aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100">
                                        <div class="bt-progress__bar" style="width: @ToCssPercent(progressPercent);"></div>
                                    </div>
                                }
                                else
                                {
                                    <div class="tcard-progress-na">Bonding Curve: n/a</div>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (CanLoadMore)
                {
                    <div class="load-more-wrap">
                        <button type="button"
                                class="btn-load-more"
                                disabled="@_loadingMore"
                                @onclick="LoadMoreAsync">
                            @(_loadingMore ? "Loading..." : "Load more")
                        </button>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div id="riskInfoModal" class="risk-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="riskModalTitle">
    <div class="risk-modal-backdrop" data-risk-modal-close="true"></div>
    <div class="risk-modal-dialog" role="document">
        <div class="risk-modal-header">
            <h3 id="riskModalTitle" class="risk-modal-title">Risk details</h3>
            <button type="button" class="risk-modal-close" aria-label="Close" data-risk-modal-close="true">×</button>
        </div>

        <div class="risk-modal-body">
            <div id="risk-single-view">
                <div class="risk-single-heading">
                    <h4 id="risk-single-title" class="risk-single-title"></h4>
                    <span id="risk-single-severity-badge" class="risk-severity-badge"></span>
                </div>
                <p id="risk-single-short" class="risk-single-short"></p>
                <p id="risk-single-why" class="risk-single-why"></p>
                <div id="risk-single-impact" class="risk-single-impact"></div>
                <div id="risk-contribution-wrap" class="risk-contribution-wrap is-hidden">
                    <div class="risk-contribution-label">Contribution to total score</div>
                    <div class="risk-contribution-bar">
                        <div id="risk-contribution-fill" class="risk-contribution-fill"></div>
                    </div>
                    <div id="risk-contribution-text" class="risk-contribution-text"></div>
                </div>
                <div id="risk-single-reason-wrap" class="risk-single-reason-wrap">
                    <strong>Detected reason:</strong>
                    <span id="risk-single-reason"></span>
                </div>
                <button type="button" id="risk-back-hidden" class="risk-modal-btn is-hidden">Back to hidden risks</button>
                <button type="button" id="risk-show-all" class="risk-modal-btn">Show all risk categories</button>
            </div>

            <div id="risk-hidden-view" class="is-hidden">
                <h4 class="risk-single-title">Hidden risks for this token</h4>
                <div id="risk-hidden-list" class="risk-hidden-list"></div>
            </div>

            <div id="risk-all-view" class="is-hidden">
                <h4 class="risk-single-title">All risk flags explained</h4>

                <div class="risk-category">
                    <h5><span aria-hidden="true">🧑‍💻</span> Creator Behavior</h5>
                    <ul>
                        <li>Creator spam (+35)</li>
                        <li>Creator burst deploys (+30)</li>
                        <li>Name reused by creator (+15)</li>
                    </ul>
                </div>

                <div class="risk-category">
                    <h5><span aria-hidden="true">🏷</span> Identity & Branding Patterns</h5>
                    <ul>
                        <li>Duplicate name in batch (+20)</li>
                        <li>Generic hype name (+15)</li>
                        <li>Suspicious name (+10)</li>
                        <li>Very short symbol (+10)</li>
                    </ul>
                </div>

                <div class="risk-category">
                    <h5><span aria-hidden="true">🖼</span> Visual & Content Quality</h5>
                    <ul>
                        <li>Image reused (+10)</li>
                        <li>Empty description (+5)</li>
                        <li>External link in description (+10)</li>
                    </ul>
                </div>

                <div class="risk-category">
                    <h5><span aria-hidden="true">🌐</span> Transparency & Communication</h5>
                    <ul>
                        <li>No socials (+5)</li>
                        <li>Metadata changed (+5)</li>
                    </ul>
                </div>

                <button type="button" id="risk-back-single" class="risk-modal-btn">Back to selected risk</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* ========================================
       BEARTRAP THEME TOKENS
       ======================================== */
    :root {
        --bt-ink-0: #14110c;
        --bt-ink-1: #2b2418;
        --bt-ink-2: #5d5242;

        --bt-parch-0: #f3ead7;
        --bt-parch-1: #ead6b2;

        --bt-surface-0: #fffaf0;
        --bt-surface-1: #f4e5c7;
        --bt-surface-2: #efd7ad;

        --bt-gold-0: #f2c14e;
        --bt-gold-1: #c9921a;
        --bt-gold-glow: rgba(201,146,26,0.25);

        --bt-border: rgba(20,17,12,0.16);
        --bt-border-soft: rgba(20,17,12,0.10);

        --bt-shadow: 0 18px 52px rgba(20,17,12,0.16);
        --bt-shadow-hover: 0 26px 74px rgba(20,17,12,0.22);

        --bt-risk-low: #2e7d57;
        --bt-risk-med: #d6a02a;
        --bt-risk-high: #c6533d;
    }

    /* ========================================
       PAGE WRAPPER (Parchment with Depth)
       ======================================== */
    .page-wrapper {
        background: radial-gradient(900px at 12% -10%, rgba(242,193,78,0.22) 0%, transparent 55%),
                    radial-gradient(900px at 95% 0%, rgba(201,146,26,0.18) 0%, transparent 55%),
                    radial-gradient(1200px at 50% 110%, rgba(20,17,12,0.10) 0%, transparent 60%),
                    linear-gradient(180deg, var(--bt-parch-0) 0%, var(--bt-parch-1) 100%);
        min-height: 100vh;
        padding: 28px 16px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        color: var(--bt-ink-0);
    }
    
    /* ========================================
       MAIN PANEL (Glass Parchment - Stronger Separation)
       ======================================== */
    .main-panel {
        max-width: 1240px;
        margin: 0 auto;
        background: linear-gradient(135deg, rgba(255,250,240,0.72) 0%, rgba(244,229,199,0.62) 100%);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 22px;
        box-shadow: 0 28px 84px rgba(20,17,12,0.18);
        padding: 26px;
        border: 1px solid rgba(20,17,12,0.12);
    }
    
    /* ========================================
       HEADER AREA
       ======================================== */
    .header-area {
        margin-bottom: 18px;
    }
    
    .tcard-progress-section {
        margin-top: 4px;
        padding: 6px 0 0;
        border-top: 1px solid rgba(20,17,12,0.08);
    }

    .token-links {
        margin-top: 6px;
        display: flex;
        flex-wrap: wrap;
    }

    .token-link-btn {
        margin-right: 6px;
        margin-bottom: 4px;
        padding: 2px 8px;
        border-radius: 7px;
        border-color: rgba(20,17,12,0.16);
        background: rgba(255,250,240,0.64);
        color: var(--bt-ink-1);
        font-size: 0.7rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.15s ease;
    }

    .token-link-btn:hover,
    .token-link-btn:focus-visible {
        background: rgba(242,193,78,0.18);
        border-color: rgba(201,146,26,0.46);
        color: var(--bt-ink-0);
        text-decoration: none;
        outline: none;
    }

    .tcard-progress-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 7px;
        gap: 8px;
    }

    .tcard-progress-label {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--bt-ink-1);
        letter-spacing: 0.01em;
    }

    .tcard-progress-value {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--bt-gold-1);
    }

    .tcard-progress-na {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--bt-ink-2);
    }

    .bt-progress {
        width: 100%;
        height: 9px;
        background: rgba(20,17,12,0.14);
        border: 1px solid rgba(20,17,12,0.12);
        border-radius: 999px;
        overflow: hidden;
    }

    .bt-progress__bar {
        height: 100%;
        width: 0;
        background: linear-gradient(90deg, var(--bt-gold-1) 0%, var(--bt-gold-0) 100%);
        border-radius: 999px;
        transition: width 0.25s ease;
    }
    
    .dash-title {
        font-size: 2.375rem;
        font-weight: 800;
        color: var(--bt-ink-0);
        margin: 0;
        letter-spacing: -0.5px;
        border: 2px solid var(--bt-ink-0);
        padding: 12px 20px;
        border-radius: 8px;
        display: inline-block;
        box-sizing: border-box;
    }

    .dash-subtitle {
        margin-top: 7px;
        margin-bottom: 16px;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: #d4a017;
        text-shadow: 0 1px 6px rgba(201,146,26,0.20);
    }

    .subtitle-inline {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        max-width: 100%;
    }

    .edition-badge {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        border-radius: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        line-height: 1.25;
        color: var(--bt-ink-2);
        background: rgba(255, 250, 240, 0.70);
        border: 1px solid var(--bt-border-soft);
        white-space: nowrap;
    }
    
     /* ========================================
         CONTROLS GRID
         ======================================== */
    .controls-grid {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
        align-items: center;
    }

    .order-wrapper {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        flex: 0 0 auto;
    }

    .order-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--bt-ink-2);
        margin: 0;
        white-space: nowrap;
    }

    .order-select {
        height: 38px;
        border-radius: 10px;
        border: 1px solid var(--bt-border-soft);
        background: rgba(255,250,240,0.90);
        color: var(--bt-ink-1);
        padding: 0 10px;
        font-size: 0.84rem;
        font-weight: 600;
    }

    .order-select:focus {
        outline: none;
        border-color: rgba(201,146,26,0.55);
        box-shadow: 0 0 0 3px rgba(242,193,78,0.20);
    }
    
    .search-wrapper {
        flex: 1 1 auto;
        min-width: 300px;
        position: relative;
        display: flex;
        align-items: center;
        padding: 0;
        line-height: normal;
    }

    .search-icon {
        width: 18px;
        height: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        color: #bfa14a;
        opacity: 0.9;
    }

    .search-trigger {
        position: absolute;
        right: 8px;
        top: 50%;
        transform: translateY(-50%);
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: 1px solid var(--bt-border-soft);
        background: rgba(255,250,240,0.92);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .search-trigger:hover,
    .search-trigger:focus-visible {
        border-color: rgba(201,146,26,0.46);
        background: var(--bt-surface-0);
        outline: none;
    }
    
    .search-pill {
        width: 100%;
        height: 46px;
        border-radius: 14px;
        border: 1px solid var(--bt-border-soft);
        padding: 0 52px 0 18px;
        font-size: 0.9375rem;
        background: rgba(255,250,240,0.90);
        box-shadow: 0 6px 18px rgba(20,17,12,0.08);
        transition: all 0.2s ease;
        color: var(--bt-ink-1);
    }
    
    .search-pill::placeholder {
        color: var(--bt-ink-2);
    }
    
    .search-pill:focus {
        outline: none;
        border-color: rgba(201,146,26,0.55);
        box-shadow: 0 6px 20px rgba(20,17,12,0.10), 0 0 0 4px rgba(242,193,78,0.28);
        background: var(--bt-surface-0);
        transform: translateY(-1px);
    }

    .search-note {
        margin-top: 7px;
        font-size: 0.75rem;
        font-weight: 500;
        line-height: 1.4;
        color: var(--bt-ink-2);
        opacity: 0.75;
        background: none;
        border: none;
        box-shadow: none;
    }
    
    /* ========================================
       TOKENS CONTENT AREA
       ======================================== */
    .tokens-content {
        margin-top: 18px;
    }
    
    .loading-state, .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--bt-ink-2);
        font-size: 0.9375rem;
    }

    .empty-link {
        border: none;
        background: none;
        color: var(--bt-ink-1);
        font-size: 0.86rem;
        font-weight: 600;
        text-decoration: underline;
        text-underline-offset: 3px;
        cursor: pointer;
    }

    .empty-link:hover,
    .empty-link:focus-visible {
        color: var(--bt-ink-0);
        outline: none;
    }

    .load-more-wrap {
        display: flex;
        justify-content: center;
        margin-top: 16px;
    }

    .btn-load-more {
        padding: 9px 18px;
        border-radius: 10px;
        border: 1px solid rgba(201,146,26,0.32);
        background: linear-gradient(145deg, rgba(242,193,78,0.16), rgba(255,250,240,0.62));
        color: var(--bt-ink-1);
        font-size: 0.84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-load-more:hover:not(:disabled),
    .btn-load-more:focus-visible:not(:disabled) {
        border-color: rgba(201,146,26,0.50);
        background: linear-gradient(145deg, rgba(242,193,78,0.24), rgba(255,250,240,0.72));
        outline: none;
    }

    .btn-load-more:disabled {
        opacity: 0.65;
        cursor: default;
    }
    
    /* ========================================
       TOKEN GRID (2 columns)
       ======================================== */
    .token-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
        width: 100%;
        max-width: 100%;
        min-width: 0;
    }
    
    /* ========================================
       TOKEN CARD (Higher Contrast + Gold Hover)
       ======================================== */
    .tcard {
        background: linear-gradient(145deg, var(--bt-surface-0), var(--bt-surface-1));
        border-radius: 16px;
        box-shadow: 0 12px 34px rgba(20,17,12,0.13);
        padding: 12px;
        transition: all 0.25s ease;
        border: 1px solid var(--bt-border);
        display: flex;
        flex-direction: column;
        gap: 8px;
        position: relative;
        overflow: hidden;
        min-width: 0;
    }

    .tcard::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(700px at 20% 0%, rgba(255,255,255,0.55) 0%, transparent 45%);
        pointer-events: none;
        z-index: 0;
    }

    .tcard > * {
        position: relative;
        z-index: 1;
    }
    
    .tcard:hover {
        box-shadow: 0 18px 48px rgba(20,17,12,0.18);
        transform: translateY(-2px);
        border-color: rgba(201,146,26,0.30);
    }
    
    /* ========================================
       TOP SECTION (Avatar + Metadata | Gauge)
       ======================================== */
    .tcard-top {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
        position: relative;
        padding-right: 136px;
        min-height: 78px;
    }
    
    .tleft {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
        min-width: 0;
    }
    
    .timg {
        width: 88px;
        height: 88px;
        min-width: 88px;
        border-radius: 18px;
        object-fit: cover;
        background: linear-gradient(135deg, var(--bt-surface-0) 0%, var(--bt-surface-1) 100%);
        box-shadow: 0 6px 18px rgba(20,17,12,0.16);
        border: 1px solid var(--bt-border-soft);
        transition: box-shadow 0.2s ease;
    }
    
    .timg:hover {
        box-shadow: 0 8px 22px rgba(20,17,12,0.20);
    }
    
    .tmeta {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
    
    .tname-row {
        display: flex;
        align-items: center;
        gap: 7px;
    }
    
    .tname {
        font-size: 1rem;
        font-weight: 700;
        color: var(--bt-ink-0);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .tchain-pill {
        font-size: 0.6875rem;
        font-weight: 700;
        color: var(--bt-ink-2);
        padding: 3px 7px;
        background: rgba(20,17,12,0.06);
        border-radius: 6px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }
    
    .addr-stack {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
        width: 100%;
        min-width: 0;
        max-width: 360px;
    }

    .addr-row {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
        background: rgba(255,255,255,0.35);
        border: 1px solid rgba(201,146,26,0.22);
        border-radius: 10px;
        padding: 5px 10px;
    }

    .addr-label {
        flex: 0 0 54px;
        min-width: 54px;
        font-size: 0.69rem;
        font-weight: 600;
        color: var(--bt-ink-2);
        letter-spacing: 0.01em;
        line-height: 1.2;
    }

    .addr-value {
        min-width: 0;
        flex: 1 1 auto;
        max-width: none;
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--bt-ink-1);
        font-family: ui-monospace, 'Cascadia Code', 'Courier New', monospace;
        text-decoration: none;
        border-bottom: none;
        transition: color 0.2s ease;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.2;
    }

    .addr-value:hover,
    .addr-value:focus-visible {
        color: var(--bt-ink-0);
        text-decoration: none;
        border-bottom: none;
        outline: none;
    }

    .addr-actions {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-left: auto;
        flex: 0 0 auto;
        flex-shrink: 0;
    }

    .addr-copy,
    .addr-open {
        width: 22px;
        height: 22px;
        padding: 0;
        font-size: 0.8125rem;
        background: rgba(255,250,240,0.68);
        border: 1px solid var(--bt-border-soft);
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--bt-ink-2);
        flex-shrink: 0;
        text-decoration: none;
    }

    .addr-copy:hover,
    .addr-copy:focus-visible,
    .addr-open:hover,
    .addr-open:focus-visible {
        background: rgba(242,193,78,0.14);
        border-color: rgba(201,146,26,0.34);
        color: var(--bt-ink-0);
        outline: none;
        text-decoration: none;
    }
    
    /* ========================================
       RIGHT SECTION (Gauge + Risk Pill)
       ======================================== */
    .tright {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
        position: absolute;
        top: 16px;
        right: 16px;
    }
    
    /* ========================================
       PREMIUM SVG GAUGE (BearTrap Colors)
       ======================================== */
    .risk-gauge {
        position: relative;
        width: 120px;
        height: 70px;
    }
    
    .gauge-svg {
        width: 100%;
        height: 100%;
        filter: drop-shadow(0 4px 8px rgba(20,17,12,0.14));
    }
    
    .gauge-bg {
        shape-rendering: geometricPrecision;
        stroke-dasharray: 100;
        stroke-dashoffset: 0;
        stroke: rgba(20,17,12,0.18);
    }
    
    .gauge-fg {
        shape-rendering: geometricPrecision;
        stroke-dasharray: 100;
        stroke-dashoffset: calc(100 - var(--p));
        transition: stroke-dashoffset 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .gauge-content {
        position: absolute;
        top: 52%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        pointer-events: none;
    }
    
    .gauge-num {
        font-size: 1.5rem;
        font-weight: 750;
        line-height: 1;
        color: var(--bt-ink-0);
        letter-spacing: -0.8px;
        margin-bottom: 1px;
    }
    
    .gauge-label {
        font-size: 0.75rem;
        font-weight: 600;
        line-height: 1;
        letter-spacing: 0.01em;
    }
    
    .gauge-label-info {
        color: var(--bt-risk-low);
    }
    
    .gauge-label-warn {
        color: var(--bt-risk-med);
    }
    
    .gauge-label-danger {
        color: var(--bt-risk-high);
    }
    
    /* Risk pill styles removed - now integrated into gauge */
    
    /* ========================================
       BOTTOM STRIP (Creator + Flags)
       ======================================== */
    .tcard-bottom {
        display: block;
        min-width: 0;
        padding-top: 8px;
        border-top: 1px solid rgba(20,17,12,0.08);
    }

    .risk-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: nowrap;
        min-width: 0;
    }

    .risk-pills {
        display: flex;
        gap: 8px;
        flex-wrap: nowrap;
        overflow: hidden;
        align-items: center;
        min-width: 0;
        flex: 1 1 auto;
    }

    [data-risk-container] {
        display: flex;
        gap: 8px;
        flex-wrap: nowrap;
        overflow: hidden;
        align-items: center;
        min-width: 0;
    }

    .risk-more {
        flex: 0 0 auto;
        white-space: nowrap;
        display: none;
        cursor: pointer;
    }

    .risk-more.is-visible {
        display: inline-flex;
    }

    .flag-chip,
    .flags-more-wrap,
    .more-chip {
        flex: 0 0 auto;
    }

    .is-hidden {
        display: none !important;
    }
    
    .tchip {
        padding: 4px 8px;
        border-radius: 9px;
        font-size: 0.66rem;
        font-weight: 600;
        white-space: nowrap;
        transition: all 0.15s ease;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    [data-risk-pill] {
        cursor: pointer;
    }
    
    .tchip-flag {
        background: rgba(255,250,240,0.55);
        color: var(--bt-ink-2);
        border: 1px solid rgba(20,17,12,0.14);
    }
    
    .tchip-more {
        background: rgba(255,250,240,0.55);
        color: var(--bt-ink-2);
        border: 1px solid rgba(20,17,12,0.14);
    }

    .tchip-button {
        cursor: pointer;
        background: rgba(255,250,240,0.7);
    }

    .tchip-button:hover {
        background: rgba(255,250,240,0.92);
        border-color: rgba(201,146,26,0.45);
        color: var(--bt-ink-1);
    }

    .tchip-button:focus-visible {
        outline: none;
        border-color: rgba(201,146,26,0.58);
        box-shadow: 0 0 0 3px rgba(242,193,78,0.26);
    }

    .flags-more-wrap {
        position: relative;
        display: inline-flex;
        align-items: center;
    }

    .flags-popover {
        position: absolute;
        bottom: calc(100% + 8px);
        right: 0;
        min-width: 210px;
        max-width: 290px;
        max-height: 190px;
        overflow-y: auto;
        padding: 10px;
        border-radius: 12px;
        border: 1px solid rgba(201,146,26,0.42);
        background: linear-gradient(145deg, rgba(255,250,240,0.98), rgba(244,229,199,0.95));
        box-shadow: 0 14px 34px rgba(20,17,12,0.24);
        z-index: 40;
    }

    .flags-popover-title {
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--bt-ink-1);
        margin-bottom: 8px;
        letter-spacing: 0.01em;
    }

    .flags-list {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .flags-popover-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 5px 7px;
        border-radius: 8px;
        border: 1px solid rgba(20,17,12,0.10);
        background: rgba(255,255,255,0.56);
        color: var(--bt-ink-1);
        font-size: 0.68rem;
        font-weight: 600;
    }

    .flags-popover-label {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
    }

    .flags-popover-points {
        color: var(--bt-risk-high);
        font-size: 0.66rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .flags-popover-close {
        margin-top: 8px;
        width: 100%;
        border: 1px solid rgba(201,146,26,0.32);
        border-radius: 8px;
        padding: 5px 8px;
        font-size: 0.7rem;
        font-weight: 600;
        background: rgba(242,193,78,0.16);
        color: var(--bt-ink-1);
        cursor: pointer;
    }

    .flags-popover-close:hover,
    .flags-popover-close:focus-visible {
        background: rgba(242,193,78,0.24);
        border-color: rgba(201,146,26,0.46);
        outline: none;
    }
    
    .tchip-clean {
        background: rgba(46,125,87,0.12);
        color: var(--bt-risk-low);
        border: 1px solid rgba(46,125,87,0.18);
    }
    
    .tchip:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 6px rgba(20,17,12,0.12);
    }
    
    /* ========================================
       COPY TOOLTIP (Gold & Ink)
       ======================================== */
    .copy-tooltip {
        position: fixed;
        background: linear-gradient(135deg, var(--bt-gold-0), var(--bt-gold-1));
        color: var(--bt-ink-0);
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        pointer-events: none;
        z-index: 10000;
        white-space: nowrap;
        box-shadow: 0 10px 26px rgba(201,146,26,0.28);
        animation: fadeInOut 800ms ease-in-out;
    }

    .risk-modal {
        position: fixed;
        inset: 0;
        z-index: 1200;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .risk-modal.is-open {
        display: flex;
    }

    .risk-modal-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(20,17,12,0.48);
    }

    .risk-modal-dialog {
        position: relative;
        width: min(640px, 100%);
        max-height: 85vh;
        overflow: auto;
        border-radius: 14px;
        border: 1px solid rgba(20,17,12,0.14);
        background: linear-gradient(145deg, rgba(255,250,240,0.98), rgba(244,229,199,0.95));
        box-shadow: 0 20px 40px rgba(20,17,12,0.28);
        padding: 14px;
    }

    .risk-modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 8px;
    }

    .risk-modal-title,
    .risk-single-title {
        margin: 0;
        color: var(--bt-ink-1);
        font-size: 1rem;
        font-weight: 700;
    }

    .risk-single-heading {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 4px;
        flex-wrap: wrap;
    }

    .risk-severity-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 2px 8px;
        font-size: 0.7rem;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .risk-severity-badge.low {
        color: #1f6b4b;
        background: rgba(46,125,87,0.14);
        border-color: rgba(46,125,87,0.24);
    }

    .risk-severity-badge.medium {
        color: #915f0a;
        background: rgba(214,160,42,0.17);
        border-color: rgba(214,160,42,0.28);
    }

    .risk-severity-badge.high {
        color: #9f342a;
        background: rgba(198,83,61,0.16);
        border-color: rgba(198,83,61,0.30);
    }

    .risk-modal-close {
        border: 1px solid rgba(20,17,12,0.14);
        background: rgba(255,250,240,0.82);
        border-radius: 8px;
        width: 30px;
        height: 30px;
        line-height: 1;
        font-size: 1.2rem;
        cursor: pointer;
        color: var(--bt-ink-1);
    }

    .risk-single-short,
    .risk-single-why,
    .risk-single-impact,
    .risk-single-reason-wrap {
        margin: 0 0 8px 0;
        font-size: 0.86rem;
        color: var(--bt-ink-2);
    }

    .risk-contribution-wrap {
        margin: 0 0 8px 0;
    }

    .risk-contribution-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--bt-ink-2);
        margin-bottom: 4px;
    }

    .risk-contribution-bar {
        width: 100%;
        height: 7px;
        border-radius: 999px;
        overflow: hidden;
        background: rgba(20,17,12,0.12);
        border: 1px solid rgba(20,17,12,0.10);
        margin-bottom: 4px;
    }

    .risk-contribution-fill {
        height: 100%;
        width: 0;
        border-radius: 999px;
        transition: width 200ms ease;
    }

    .risk-contribution-fill.low {
        background: linear-gradient(90deg, rgba(46,125,87,0.85), rgba(46,125,87,0.65));
    }

    .risk-contribution-fill.medium {
        background: linear-gradient(90deg, rgba(214,160,42,0.9), rgba(214,160,42,0.7));
    }

    .risk-contribution-fill.high {
        background: linear-gradient(90deg, rgba(198,83,61,0.9), rgba(198,83,61,0.72));
    }

    .risk-contribution-text {
        font-size: 0.76rem;
        font-weight: 600;
        color: var(--bt-ink-2);
    }

    .risk-category {
        margin-bottom: 10px;
    }

    .risk-category + .risk-category {
        margin-top: 12px;
        padding-top: 10px;
        border-top: 1px solid rgba(20,17,12,0.10);
    }

    .risk-category h5 {
        margin: 0 0 4px 0;
        font-size: 0.86rem;
        color: var(--bt-ink-1);
        font-weight: 700;
    }

    .risk-category ul {
        margin: 0;
        padding-left: 18px;
        color: var(--bt-ink-2);
        font-size: 0.83rem;
    }

    .risk-modal-btn {
        border: 1px solid rgba(201,146,26,0.36);
        background: rgba(255,250,240,0.9);
        border-radius: 8px;
        padding: 6px 10px;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--bt-ink-1);
        cursor: pointer;
    }

    .risk-hidden-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .risk-hidden-item {
        width: 100%;
        text-align: left;
        border: 1px solid rgba(20,17,12,0.10);
        border-radius: 10px;
        padding: 8px 10px;
        background: rgba(255,255,255,0.56);
        color: var(--bt-ink-1);
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
    }

    .risk-hidden-item:hover,
    .risk-hidden-item:focus-visible {
        border-color: rgba(201,146,26,0.42);
        background: rgba(255,250,240,0.9);
        outline: none;
    }

    @@media (max-width: 560px) {
        .risk-modal {
            padding: 10px;
        }

        .risk-modal-dialog {
            width: 100%;
            max-height: 88vh;
            padding: 12px;
        }

        .risk-modal-btn {
            width: 100%;
        }
    }
    
    @@keyframes fadeInOut {
        0% { opacity: 0; transform: translateY(6px); }
        20% { opacity: 1; transform: translateY(0); }
        80% { opacity: 1; transform: translateY(0); }
        100% { opacity: 0; transform: translateY(-6px); }
    }
    
    /* ========================================
       RESPONSIVE DESIGN
       ======================================== */
    @@media (min-width: 769px) {
        .token-header {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            padding-right: 0;
            min-height: 88px;
            min-width: 0;
        }

        .tleft {
            flex: 1 1 auto;
            min-width: 0;
            align-items: flex-start;
            gap: 16px;
        }

        .token-avatar {
