<script>
    window.copyToClipboard = function(text) {
        // Copy to clipboard
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(function() {
                showCopiedTooltip(event);
            }).catch(function(err) {
                console.error('Failed to copy:', err);
            });
        } else {
            // Fallback for older browsers
            const textArea = document.createElement('textarea');
            textArea.value = text;
            textArea.style.position = 'fixed';
            textArea.style.opacity = '0';
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            try {
                document.execCommand('copy');
                showCopiedTooltip(event);
            } catch (err) {
                console.error('Failed to copy:', err);
            }
            document.body.removeChild(textArea);
        }
    };
    
    function showCopiedTooltip(event) {
        // Get button position
        const button = event.target;
        const rect = button.getBoundingClientRect();
        
        // Create tooltip
        const tooltip = document.createElement('div');
        tooltip.className = 'copy-tooltip';
        tooltip.textContent = 'Copied!';
        tooltip.style.left = rect.left + (rect.width / 2) + 'px';
        tooltip.style.top = (rect.top - 40) + 'px';
        tooltip.style.transform = 'translateX(-50%)';
        
        document.body.appendChild(tooltip);
        
        // Remove after animation (800ms)
        setTimeout(function() {
            if (document.body.contains(tooltip)) {
                document.body.removeChild(tooltip);
            }
        }, 800);
    }

    (function () {
        const riskDescriptions = {
            EMPTY_DESCRIPTION: { short: "Token description is empty or extremely short.", why: "Legitimate projects usually provide at least minimal context." },
            CREATOR_SPAM: { short: "Creator deployed 3+ tokens in the last 24 hours.", why: "High-frequency launches are common in spam factories." },
            CREATOR_BURST: { short: "Creator deployed many tokens in the current batch.", why: "Burst launches can indicate factory-like behavior." },
            NAME_REUSED: { short: "The same creator reused token name or symbol.", why: "Name/symbol recycling can indicate low-effort repeated launches." },
            DUPLICATE_NAME_IN_BATCH: { short: "Name appears multiple times in one batch.", why: "Repeated naming in short time can indicate copycat/spam patterns." },
            NAME_TOO_GENERIC: { short: "Name contains multiple generic hype keywords.", why: "Overly generic branding is common in low-quality launches." },
            NAME_SUS: { short: "Name/symbol matched suspicious pattern.", why: "Contains scam-like terms, URL fragments, or suspicious symbols." },
            SYMBOL_TOO_SHORT: { short: "Token symbol is very short.", why: "Extremely short symbols are often used by low-effort spam tokens." },
            SYMBOL_RANDOMIZED: { short: "Symbol appears randomized/spam-like.", why: "Pattern may look auto-generated rather than branded." },
            IMAGE_REUSED: { short: "Image URL is reused by multiple tokens.", why: "Visual reuse may suggest cloned projects." },
            LINK_IN_DESCRIPTION: { short: "Description contains external link.", why: "External links in token description can be used for phishing." },
            NO_SOCIALS: { short: "No website, Telegram, or Twitter found.", why: "Lack of communication channels reduces transparency." },
            METADATA_CHANGED: { short: "Token metadata changed after creation.", why: "Late metadata edits can be benign or suspicious depending on context." }
        };

        const modal = document.getElementById('riskInfoModal');
        const singleView = document.getElementById('risk-single-view');
        const hiddenView = document.getElementById('risk-hidden-view');
        const hiddenList = document.getElementById('risk-hidden-list');
        const allView = document.getElementById('risk-all-view');
        const singleTitle = document.getElementById('risk-single-title');
        const singleShort = document.getElementById('risk-single-short');
        const singleWhy = document.getElementById('risk-single-why');
        const singleImpact = document.getElementById('risk-single-impact');
        const singleSeverityBadge = document.getElementById('risk-single-severity-badge');
        const contributionWrap = document.getElementById('risk-contribution-wrap');
        const contributionFill = document.getElementById('risk-contribution-fill');
        const contributionText = document.getElementById('risk-contribution-text');
        const singleReasonWrap = document.getElementById('risk-single-reason-wrap');
        const singleReason = document.getElementById('risk-single-reason');
        const backHiddenButton = document.getElementById('risk-back-hidden');
        const showAllButton = document.getElementById('risk-show-all');
        const backButton = document.getElementById('risk-back-single');

        let hiddenRisksCache = [];

        if (!modal || !singleView || !hiddenView || !hiddenList || !allView) {
            return;
        }

        function normalizeSeverity(rawSeverity) {
            const value = (rawSeverity || '').toLowerCase();
            if (value === 'high') return 'High';
            if (value === 'medium') return 'Medium';
            return 'Low';
        }

        function openModal() {
            modal.classList.add('is-open');
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            modal.classList.remove('is-open');
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        function showSingleView() {
            singleView.classList.remove('is-hidden');
            hiddenView.classList.add('is-hidden');
            allView.classList.add('is-hidden');
        }

        function showHiddenView() {
            singleView.classList.add('is-hidden');
            hiddenView.classList.remove('is-hidden');
            allView.classList.add('is-hidden');
        }

        function showAllView() {
            singleView.classList.add('is-hidden');
            hiddenView.classList.add('is-hidden');
            allView.classList.remove('is-hidden');
        }

        function renderHiddenRisks(items) {
            hiddenList.innerHTML = '';

            if (!items.length) {
                const empty = document.createElement('div');
                empty.className = 'risk-single-why';
                empty.textContent = 'No hidden risks for this token.';
                hiddenList.appendChild(empty);
                return;
            }

            for (const item of items) {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'risk-hidden-item';
                button.setAttribute('data-risk-pill', 'true');
                button.setAttribute('data-risk-code', item.code || '');
                button.setAttribute('data-risk-title', item.title || 'Risk flag');
                button.setAttribute('data-risk-points', `${item.points ?? 0}`);
                button.setAttribute('data-total-score', `${item.totalScore ?? 0}`);
                button.setAttribute('data-risk-severity', item.severity || 'low');
                button.setAttribute('data-risk-reason', item.reason || '');
                button.textContent = `${item.title || 'Risk flag'} (+${item.points ?? 0})`;
                hiddenList.appendChild(button);
            }
        }

        function openRiskDetails(pill, fromHiddenView = false) {
            const riskCode = pill.dataset.riskCode || '';
            const riskTitle = pill.dataset.riskTitle || pill.textContent?.trim() || 'Risk flag';
            const riskPoints = pill.dataset.riskPoints || '0';
            const totalScore = pill.dataset.totalScore || '0';
            const riskSeverity = normalizeSeverity(pill.dataset.riskSeverity);
            const severityKey = (pill.dataset.riskSeverity || 'low').toLowerCase();
            const riskReason = (pill.dataset.riskReason || '').trim();

            const mapping = riskDescriptions[riskCode] || {
                short: `${riskTitle}.`,
                why: 'This flag indicates a potential risk pattern detected in token metadata or behavior.'
            };

            singleTitle.textContent = riskTitle;
            singleShort.textContent = mapping.short;
            singleWhy.textContent = mapping.why;
            singleImpact.textContent = `Risk impact: +${riskPoints} points · Severity: ${riskSeverity}`;

            if (singleSeverityBadge) {
                singleSeverityBadge.textContent = riskSeverity;
                singleSeverityBadge.classList.remove('low', 'medium', 'high');
                singleSeverityBadge.classList.add(severityKey);
            }

            if (backHiddenButton) {
                backHiddenButton.classList.toggle('is-hidden', !fromHiddenView || hiddenRisksCache.length === 0);
            }

            const pointsValue = Number.parseInt(riskPoints, 10) || 0;
            const totalScoreValue = Number.parseInt(totalScore, 10) || 0;

            if (contributionWrap && contributionFill && contributionText) {
                if (totalScoreValue <= 0) {
                    contributionWrap.classList.add('is-hidden');
                    contributionFill.style.width = '0%';
                    contributionFill.classList.remove('low', 'medium', 'high');
                    contributionText.textContent = '';
                }
                else {
                    const rawPercent = Math.round((pointsValue / totalScoreValue) * 100);
                    const percent = Math.max(0, Math.min(100, rawPercent));

                    contributionWrap.classList.remove('is-hidden');
                    contributionFill.classList.remove('low', 'medium', 'high');
                    contributionFill.classList.add(severityKey);
                    contributionFill.style.width = `${percent}%`;
                    contributionText.textContent = `${pointsValue} / ${totalScoreValue} (${percent}%)`;
                }
            }

            const reasonNormalized = riskReason.toLowerCase();
            const shortNormalized = (mapping.short || '').trim().toLowerCase();
            const whyNormalized = (mapping.why || '').trim().toLowerCase();
            const shouldShowReason = reasonNormalized.length > 0 && reasonNormalized !== shortNormalized && reasonNormalized !== whyNormalized;

            if (shouldShowReason) {
                singleReason.textContent = riskReason;
                singleReasonWrap.classList.remove('is-hidden');
            }
            else {
                singleReason.textContent = '';
                singleReasonWrap.classList.add('is-hidden');
            }

            showSingleView();
            openModal();
        }

        document.addEventListener('click', (event) => {
            const pill = event.target.closest('[data-risk-pill]');
            if (pill) {
                const fromHiddenView = !!pill.closest('#risk-hidden-view');
                openRiskDetails(pill, fromHiddenView);
                return;
            }

            const moreChip = event.target.closest('[data-risk-more]');
            if (moreChip) {
                let parsed = [];
                const raw = moreChip.dataset.hiddenRisks;

                if (raw) {
                    try {
                        parsed = JSON.parse(raw);
                    }
                    catch {
                        parsed = [];
                    }
                }

                hiddenRisksCache = Array.isArray(parsed) ? parsed : [];
                renderHiddenRisks(hiddenRisksCache);
                showHiddenView();
                openModal();
                return;
            }

            if (event.target.closest('[data-risk-modal-close]')) {
                closeModal();
                return;
            }
        });

        showAllButton?.addEventListener('click', showAllView);
        backButton?.addEventListener('click', showSingleView);
        backHiddenButton?.addEventListener('click', () => {
            renderHiddenRisks(hiddenRisksCache);
            showHiddenView();
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && modal.classList.contains('is-open')) {
                closeModal();
            }
        });
    })();
</script>

@code {
    private static string GetScoreSeverity(int score)
    {
        if (score >= 60) return "danger";
        if (score >= 30) return "warn";
        return "info";
    }
    
    private static string GetRiskLabel(int score)
    {
        if (score >= 60) return "High";
        if (score >= 30) return "Medium";
        return "Low";
    }

    private static decimal ClampProgressPercent(decimal value)
        => Math.Clamp(value, 0m, 100m);

    private static string ToCssPercent(decimal value)
        => $"{ClampProgressPercent(value).ToString("0.##", CultureInfo.InvariantCulture)}%";

    private static string GetFourMemeTokenUrl(string? address)
        => $"https://four.meme/token/{Uri.EscapeDataString((address ?? string.Empty).Trim())}";

    private static string GetFourMemeUserUrl(string? creatorUserId)
        => $"https://four.meme/user/{Uri.EscapeDataString((creatorUserId ?? string.Empty).Trim())}";

    private static List<TokenLink> BuildTokenLinks(LatestToken token, RiskReport report)
    {
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var links = new List<TokenLink>();

        AddTokenLink(token.WebUrl, seen, links);
        AddTokenLink(token.TwitterUrl, seen, links);
        AddTokenLink(token.TelegramUrl, seen, links);

        foreach (var descriptionLink in report.DescriptionLinks)
        {
            AddTokenLink(descriptionLink, seen, links);
        }

        return links;
    }

    private static void AddTokenLink(string? rawUrl, HashSet<string> seen, List<TokenLink> links)
    {
        var normalizedUrl = NormalizeTokenLinkUrl(rawUrl);
        if (string.IsNullOrWhiteSpace(normalizedUrl))
        {
            return;
        }

        if (!seen.Add(normalizedUrl))
        {
            return;
        }

        links.Add(new TokenLink(
            normalizedUrl,
            GetLinkLabel(normalizedUrl)));
    }

    private static string? NormalizeTokenLinkUrl(string? rawUrl)
    {
        if (string.IsNullOrWhiteSpace(rawUrl))
        {
            return null;
        }

        var trimmed = rawUrl.Trim().TrimEnd('.', ',', ';', ':', '!', '?', ')', ']', '}');
        if (trimmed.StartsWith("www.", StringComparison.OrdinalIgnoreCase))
        {
            trimmed = $"https://{trimmed}";
        }

        if (!Uri.TryCreate(trimmed, UriKind.Absolute, out var uri))
        {
            return null;
        }

        if (!string.Equals(uri.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(uri.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return uri.AbsoluteUri;
    }

    private static string GetLinkLabel(string url)
    {
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            return url;
        }

        var host = uri.Host.StartsWith("www.", StringComparison.OrdinalIgnoreCase)
            ? uri.Host[4..]
            : uri.Host;

        var path = uri.AbsolutePath.Trim('/');
        if (string.IsNullOrWhiteSpace(path))
        {
            return host;
        }

        var firstPathSegment = path.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        return string.IsNullOrWhiteSpace(firstPathSegment)
            ? host
            : $"{host}/{firstPathSegment}";
    }

    private sealed record TokenLink(string Url, string Label);
}

@code {
    private bool _loading = true;
    private List<(LatestToken Token, RiskReport Report)> _results = new();
    private bool _flagsOverflowRegistered;
    
    // Search state
    private string _searchQuery = string.Empty;
    private string _activeQuery = string.Empty;
    private FourMemeOrderBy _selectedOrderBy = FourMemeOrderBy.TimeDesc;
    private int _searchPageIndex = 1;
    private bool _hasMoreSearchPages;
    private bool _loadingMore;
    private CancellationTokenSource? _requestCts;

    private const int LatestPageSize = 6;
    private const int SearchPageSize = 20;
    private const int SearchMaxPages = 5;
    private const int EnrichmentMaxConcurrency = 4;
    
    private List<(LatestToken Token, RiskReport Report)> FilteredResults => _results;

    private bool IsSearchMode => !string.IsNullOrWhiteSpace(_activeQuery);

    private bool CanLoadMore => IsSearchMode && _hasMoreSearchPages && !_loading;
    
    private async Task CopyToClipboard(string text)
    {
        await JSRuntime.InvokeVoidAsync("copyToClipboard", text);
    }

    private static string NormalizeTokenKey(string tokenAddress)
        => (tokenAddress ?? string.Empty).Trim().ToLowerInvariant();

    private static string GetFlagsContainerId(string tokenAddress)
    {
        var safeChars = tokenAddress
            .Select(ch => char.IsLetterOrDigit(ch) ? ch : '-')
            .ToArray();

        return $"flags-{new string(safeChars)}";
    }
    
    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;
    }

    private async Task OnSearchInputKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs args)
    {
        if (!string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            return;
        }

        await SearchAsync();
    }

    private Task SearchAsync()
    {
        return LoadFirstPageAsync();
    }

    private async Task OnOrderByChangedAsync(ChangeEventArgs args)
    {
        var rawValue = args?.Value?.ToString();
        if (!Enum.TryParse<FourMemeOrderBy>(rawValue, ignoreCase: true, out var selected))
        {
            selected = FourMemeOrderBy.Hot;
        }

        if (selected == FourMemeOrderBy.Query)
        {
            selected = FourMemeOrderBy.TimeDesc;
        }

        if (_selectedOrderBy == selected && string.IsNullOrWhiteSpace(_searchQuery))
        {
            return;
        }

        _selectedOrderBy = selected;
        _searchQuery = string.Empty;
        await LoadFirstPageAsync();
    }

    private async Task ShowFeaturedAsync()
    {
        _selectedOrderBy = FourMemeOrderBy.Hot;
        _searchQuery = string.Empty;
        await LoadFirstPageAsync();
    }

    private async Task LoadFirstPageAsync()
    {
        var requestCt = BeginNewRequest();

        _loading = true;
        _loadingMore = false;

        var query = (_searchQuery ?? string.Empty).Trim();

        try
        {
            await LoadTokensPageAsync(query, pageIndex: 1, append: false, requestCt);
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
            await TryRecalculateRiskFlagsAsync();
        }
    }

    private async Task LoadMoreAsync()
    {
        if (!CanLoadMore)
        {
            return;
        }

        var requestCt = BeginNewRequest();
        _loadingMore = true;

        try
        {
            await LoadTokensPageAsync(_activeQuery, _searchPageIndex + 1, append: true, requestCt);
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            _loadingMore = false;
            await InvokeAsync(StateHasChanged);
            await TryRecalculateRiskFlagsAsync();
        }
    }

    private CancellationToken BeginNewRequest()
    {
        _requestCts?.Cancel();
        _requestCts?.Dispose();
        _requestCts = new CancellationTokenSource();
        return _requestCts.Token;
    }

    private async Task LoadTokensPageAsync(string query, int pageIndex, bool append, CancellationToken ct)
    {
        ct.ThrowIfCancellationRequested();

        var normalizedQuery = (query ?? string.Empty).Trim();
        var isSearchMode = !string.IsNullOrWhiteSpace(normalizedQuery);
        var orderBy = isSearchMode ? FourMemeOrderBy.Query : _selectedOrderBy;

        var safePageIndex = Math.Max(1, pageIndex);
        var pageSize = isSearchMode ? SearchPageSize : LatestPageSize;

        var tokenDtos = await FourMemeMainListSource.QueryTokensAsync(normalizedQuery, orderBy, safePageIndex, pageSize, ct);
        var enrichedTokens = await EnrichTokensWithLimitedConcurrencyAsync(tokenDtos, ct);
        var analyzedRows = await RiskAnalyzer.AnalyzeBatchAsync(enrichedTokens, ct);

        if (append)
        {
            _results.AddRange(analyzedRows);
        }
        else
        {
            _results = analyzedRows;
        }

        _activeQuery = normalizedQuery;
        _searchPageIndex = safePageIndex;
        _hasMoreSearchPages = isSearchMode && safePageIndex < SearchMaxPages && tokenDtos.Count >= pageSize;
    }

    private static async Task<List<LatestToken>> EnrichTokensWithLimitedConcurrencyAsync(
        IReadOnlyList<TokenDto> tokenDtos,
        CancellationToken ct)
    {
        if (tokenDtos.Count == 0)
        {
            return new List<LatestToken>();
        }

        using var throttler = new SemaphoreSlim(EnrichmentMaxConcurrency);
        var tasks = tokenDtos.Select(async dto =>
        {
            await throttler.WaitAsync(ct);
            try
            {
                return new LatestToken(
                    Address: dto.Address,
                    Name: dto.Name,
                    Symbol: dto.Symbol,
                    Creator: dto.Creator,
                    CreatedAt: dto.CreatedAt,
                    ImageUrl: dto.ImageUrl,
                    ProgressPercent: dto.ProgressPercent.HasValue
                        ? ClampProgressPercent(dto.ProgressPercent.Value)
                        : null,
                    CreatorUserId: dto.CreatorUserId,
                    WebUrl: dto.WebUrl,
                    TelegramUrl: dto.TelegramUrl,
                    TwitterUrl: dto.TwitterUrl,
                    ModifiedAt: dto.ModifiedAt,
                    Description: dto.Description,
                    Desc: dto.Desc,
                    Extra: dto.Extra);
            }
            finally
            {
                throttler.Release();
            }
        });

        var mapped = await Task.WhenAll(tasks);
        return mapped.ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadFirstPageAsync();
        }

        if (!_flagsOverflowRegistered)
        {
            await JSRuntime.InvokeVoidAsync("flagsOverflow.register");
            _flagsOverflowRegistered = true;
        }

        await TryRecalculateRiskFlagsAsync();
    }

    private async Task TryRecalculateRiskFlagsAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("recalculateAllRiskFlags");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[flagsOverflow] JS interop error: {ex}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        _requestCts?.Cancel();
        _requestCts?.Dispose();

        try
        {
            await JSRuntime.InvokeVoidAsync("flagsOverflow.dispose");
        }
        catch
